# =====================================================
# 交易所 API 金鑰（只需 Read 權限，不需 Trade 權限）
# 複製此檔案為 .env 並填入你的金鑰
# =====================================================

# Binance
BINANCE_API_KEY=
BINANCE_SECRET=

# OKX
OKX_API_KEY=
OKX_SECRET=
OKX_PASSPHRASE=

# =====================================================
# 冷錢包地址（多個地址用逗號分隔）
# =====================================================
EVM_WALLET=0xABC...,0xDEF...
BTC_WALLET=bc1q...,1A2B...

# =====================================================
# EVM RPC 端點（可選，不填則使用免費公共節點）
# 建議生產環境使用 Infura 或 Alchemy
# =====================================================
ETH_RPC_URL=
BSC_RPC_URL=
POLYGON_RPC_URL=

# =====================================================
# Telegram Bot（執行 python -m src.telegram_bot.bot）
# 從 @BotFather 取得 token
# TELEGRAM_ALLOWED_CHAT_IDS 留空表示不限制聊天室
# =====================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
